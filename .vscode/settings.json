{
    // Tests
    "cmakeExplorer.buildDir": "${workspaceFolder}/build",
    "cmakeExplorer.buildConfig": "Debug",
    "cmakeExplorer.suiteDelimiter": "-",
    "cmakeExplorer.extraCtestEnvVars": {
        "NO_COLOR": "1"
    },
    // Dictionary
    "cSpell.words": [
        "endregion",
        "rawrtc",
        "rawrtcdc",
        "wvb"
    ],
    // Hide files
    "hidefiles.configurationType": "local",
    "hidefiles.globalConfig": {
        "profiles": [
            {
                "name": "Default",
                "detail": "",
                "description": "Test",
                "hidden": [
                    ".vscode/",
                    ".idea/",
                    "cmake-build-release-visual-studio/",
                    "cmake-build-debug-wsl/",
                    "cmake-build-debug-visual-studio/",
                    "cmake-build-debug/",
                    "build/",
                    "resources/"
                ]
            },
            {
                "name": "Project Files",
                "detail": "Hide everything not immediately required",
                "hidden": [
                    "$Default",
                    ".gitmodules",
                    ".gitignore",
                    ".clang-format",
                    ".gitignore",
                    "README.md"
                ]
            },
            {
                "hidden": [
                    "$Project Files",
                    "external/"
                ],
                "name": "Project Source Files",
                "description": "",
                "detail": "",
                "peek": []
            }
        ]
    },
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true
    },
    "hidefiles.selectedProfile": "Show All Files",
}